generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../generated/zod"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------
// Enums
// -----------------------------------------------

enum RegionGroup {
  NORD
  CENTRO
  SUD
  ISOLE

  @@map("region_group")
}

enum PoiCategory {
  RESTAURANT
  MUSEUM
  PARK
  MARKET
  BAR
  LANDMARK
  VENUE
  CHURCH
  ROOFTOP
  NEIGHBORHOOD
  EVENT_VENUE
  WINERY
  EXPERIENCE_SITE
  SAGRA
  BEACH
  AGRITURISMO
  FESTIVAL
  DANCE
  STREET_FOOD
  PUB

  @@map("poi_category")
}

enum SavedItemCategory {
  RESTAURANT
  MUSEUM
  EVENT
  PLACE
  WINE
  EXPERIENCE

  @@map("saved_item_category")
}

// -----------------------------------------------
// Models
// -----------------------------------------------

/// Italian region (20 regions, seeded)
model Region {
  id    String      @id @db.VarChar(50)
  name  String      @unique @db.VarChar(100)
  group RegionGroup
  hasKb Boolean     @default(false) @map("has_kb")

  savedItems SavedItem[]
  comuni     Comune[]

  @@map("regions")
}

/// A point of interest linked to a comune (which belongs to a region).
/// Region is reached via POI → Comune → Region.
model PointOfInterest {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @db.VarChar(500)
  comuneId    String      @map("comune_id") @db.Uuid
  category    PoiCategory
  address     String?     @db.VarChar(500)
  websiteUrl  String?     @map("website_url") @db.VarChar(1000)
  mapsUrl     String?     @map("maps_url") @db.VarChar(1000)
  imageUrl    String?     @map("image_url") @db.VarChar(1000)
  description String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  comune     Comune      @relation(fields: [comuneId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  savedItems SavedItem[]

  @@unique([name, comuneId, category])
  @@index([comuneId])
  @@index([category, comuneId])
  @@map("points_of_interest")
}

/// User-bookmarked entity from chat responses
model SavedItem {
  id       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String            @map("user_id") @db.Uuid
  regionId String            @map("region_id") @db.VarChar(50)
  category SavedItemCategory
  poiId    String?           @map("poi_id") @db.Uuid
  name     String            @db.VarChar(500)
  description String         @db.Text
  address  String?           @db.VarChar(500)
  mapsUrl  String?           @map("maps_url") @db.VarChar(1000)
  website  String?           @db.VarChar(1000)
  imageUrl String?           @map("image_url") @db.VarChar(1000)
  savedAt  DateTime          @default(now()) @map("saved_at") @db.Timestamptz

  region Region           @relation(fields: [regionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  poi    PointOfInterest? @relation(fields: [poiId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([userId, name, regionId, category])
  @@index([userId, regionId])
  @@index([userId, category])
  @@map("saved_items")
}

/// Italian municipality with geographic coordinates
model Comune {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String  @db.VarChar(200)
  province  String  @db.VarChar(5)
  regionId  String  @map("region_id") @db.VarChar(50)
  latitude  Decimal @db.Decimal(10, 7)
  longitude Decimal @db.Decimal(10, 7)

  region           Region            @relation(fields: [regionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  pointsOfInterest PointOfInterest[]

  @@unique([name, regionId])
  @@index([regionId])
  @@index([province, regionId])
  @@map("comuni")
}
